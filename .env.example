# confluence-cli environment configuration
# Copy to .env and fill in. All variables are optional and overridable by CLI flags.

# Confluence site root URL (Cloud: https://your-org.atlassian.net, DC: https://confluence.example.com)
CONFLUENCE_SERVER=https://confluence.example.com/

# Backend flavor: cloud | datacenter | auto (default: auto)
CONFLUENCE_FLAVOR=auto

# --- Authentication: pick ONE scheme ---

# Data Center / Server: Personal Access Token (Bearer)
CONFLUENCE_PERSONAL_ACCESS_TOKEN=

# Basic auth (DC: username + password; Cloud: email + API token)
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=
CONFLUENCE_API_TOKEN=

# Default output format: json | table | ndjson
CONFLUENCE_FORMAT=json
